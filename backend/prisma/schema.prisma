generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url =      "file:./dev.db"
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model User {
  id            Int            @id @default(autoincrement())
  login         String         @unique
  email         String         @unique
  password      String
  name          String
  refreshTokens RefreshToken[]
}
